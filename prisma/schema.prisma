generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum BloodType {
  A_POS
  A_NEG
  B_POS
  B_NEG
  AB_POS
  AB_NEG
  O_POS
  O_NEG
}

enum Bank {
  BANCO_DO_BRASIL
  CAIXA
  SANTANDER
  ITAU
  NUBANK
  OUTRO
}

enum Punishment {
  ADVERTENCIA
  IMPEDIMENTO
  REPREENSAO
  DETENCAO
  CADEIA
}

enum Platoon {
  P1
  P2
  P3
}

model Soldier {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  squad   String   @default("Comando")
  platoon Platoon?

  photoUrl String?

  fullName String
  warName  String
  cpf      String @unique
  idt      String @unique

  phone          String
  emergencyPhone String
  naturalidade   String
  motherName     String
  fatherName     String
  address        String

  laranjeira      Boolean @default(false)
  familyHistory   String? @db.Text
  professionalExp String? @db.Text
  education       String?

  hasLicense      Boolean @default(false)
  licenseCategory String?

  bloodType BloodType?

  bank    Bank?
  agency  String?
  account String?

  religion   String?
  voterTitle String?

  isAthlete        Boolean @default(false)
  physicalActivity String?

  notesPositive String? @db.Text
  notesNegative String? @db.Text

  // ========= NOVOS CAMPOS (redes/relacionamento/saúde/drogas) =========
  facebook  String?
  instagram String?

  healthIssues String? @db.Text

  hasGirlfriend     Boolean @default(false)
  girlfriendAddress String? @db.Text

  usedDrugs    Boolean @default(false)
  drugsDetails String? @db.Text

  // ========= PERFIL SOCIAL / FAMÍLIA =========
  tattoos       String? @db.Text
  childrenCount Int?

  hasBeenArrested Boolean @default(false)
  arrestDetails   String? @db.Text

  livesWithParents Boolean @default(false)
  livesWithWhom    String? @db.Text

  lostCloseFamily Boolean @default(false)
  lostWhoCause    String? @db.Text

  livedAway      Boolean @default(false)
  livedAwayWhere String? @db.Text

  householdCount Int? // quantos moram na casa

  familyIncome      Decimal? @db.Decimal(10, 2)
  helpsFamily       Boolean  @default(false)
  helpsFamilyAmount Decimal? @db.Decimal(10, 2)

  hasSiblings   Boolean @default(false)
  siblingsCount Int?

  smoker     Boolean @default(false)
  alcoholUse Boolean @default(false)

  policeProblems        Boolean @default(false)
  policeProblemsDetails String? @db.Text

  accidentSequelae        Boolean @default(false)
  accidentSequelaeDetails String? @db.Text

  hadSurgeries     Boolean @default(false)
  surgeriesDetails String? @db.Text

  hasSTDs    Boolean @default(false)
  stdDetails String? @db.Text

  hasSeizuresFainting   Boolean @default(false)
  mentalSymptoms        Boolean @default(false)
  mentalSymptomsDetails String? @db.Text

  suddenFear Boolean @default(false)

  irritabilityAnxietyEtc        Boolean @default(false)
  irritabilityAnxietyEtcDetails String? @db.Text

  hasMilitaryRelative     Boolean @default(false)
  militaryRelativeDetails String? @db.Text

  relationshipFather   String? @db.Text
  relationshipMother   String? @db.Text
  relationshipSiblings String? @db.Text

  workedBeforeEB Boolean  @default(false)
  workSignedCard Boolean  @default(false)
  workSalary     Decimal? @db.Decimal(10, 2)
  workDetails    String?  @db.Text

  volunteeredToServe Boolean @default(false)

  fatds FATD[]
  fos   FO[]

  @@index([fullName])
  @@index([warName])
  @@index([platoon])
}

model FATD {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  soldierId String
  soldier   Soldier @relation(fields: [soldierId], references: [id], onDelete: Cascade)

  date       DateTime
  reason     String     @db.Text
  punishment Punishment

  @@index([soldierId])
  @@index([date])
}

enum FoType {
  POSITIVO
  NEGATIVO
}

model FO {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  date      DateTime @default(now())

  type FoType
  text String @db.Text

  soldierId String
  soldier   Soldier @relation(fields: [soldierId], references: [id], onDelete: Cascade)

  @@index([soldierId])
  @@index([date])
  @@index([type])
}
